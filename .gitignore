# OS generated files #
######################
*.DS_Store*
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
feat/tests/data/sampler0000.jpg
feat/tests/data/fex_s20_cv_20170330.txt
feat/tests/data/cond_pain_2017-03-30_s20_r01.txt

# Ignore jupyter-book build artifacts as they'll get auto-built via github actions
docs/**/*.csv
docs/**/*.mp4
# ...except the small bundled sample dataset the 04_fex_analysis tutorial loads.
!docs/data/news_sample/*.csv
# ...and the committed benchmark seed the live dashboard reads (live.py).
!docs/benchmarks/throughput.csv
docs/_build
docs/basic_tutorials/*.jpg
docs/basic_tutorials/*.gif
docs/basic_tutorials/figure.ipynb
docs/basic_tutorials/fig_maker

#Ignore resources folder except config files and viz model
resources/*
!resources/model_list.json
!resources/neutral_face_coordinates.csv
!resources/canonical_face_model.pt
!resources/canonical_face_tessellation.json
!resources/muscle_to_mesh_map.json

# PytestCache
.pytest_cache/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Local secrets / tokens (never commit these)
.env
.env.local

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
src/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# marimo-book build outputs (the committed _rendered/ artifact is NOT ignored)
docs/_site/
docs/_site_src/
docs/.marimo_book_cache/
# mo.persistent_cache scratch — a local re-render accelerator, not a shared
# artifact (keys embed machine-specific values); _rendered/ is the cross-machine layer.
docs/**/__marimo__/

# PyBuilder
target/

# pyenv python configuration file
.python-version

# Jupyter
_Notebooks/
.ipynb_checkpoints

# Ignore data files for AU viz model building
data/*
!data/.gitkeep

# Ignore development notebooks and code
dev/

# CPU/GPU profiling script
gpu_profiling.py

# Longer video
FNL_01.mp4

.vscode/bookmarks.json
feat/tests/*.prof

# Per-run accuracy-benchmark JSON from scripts/bench_regression.py.
# Headline numbers ship in docs/benchmarks/<date>-<sha>-accuracy.md.
bench-results/

# Local feature-extraction caches (chunks fed to AU classifier retraining).
# Multi-hundred-GB; regenerated from /Storage/Data via
# scripts/extract_au_training_features.py.
bench-cache/

# Local model training outputs (xgb_au_v3.x, pose_mlp, l2cs converted .safetensors).
# The canonical distribution channel is HuggingFace (py-feat/* repos);
# locally-trained artifacts must not be committed.
models/

# HuggingFace download cache. Auto-populated at runtime by hf_hub_download
# in feat/utils/io.py; never tracked. Includes any model weights that the
# detector pulls from py-feat/* (e.g. l2cs, xgb_au, img2pose, resmasknet).
feat/resources/.locks/
feat/resources/CACHEDIR.TAG
feat/resources/models--*/
feat/resources/*.npz
# Locally-built viz/model artifacts (canonical copies live in the HF cache
# under models--py-feat--* and are lazy-downloaded; never track loose copies).
feat/resources/*.h5
feat/resources/*.joblib
# Exception: the v2.4 AU->mesh PLS model (v4) ships bundled in the package
# (see feat/plotting.py load_face_mesh_viz_model) so it loads offline; the
# offline contract is enforced by test_face_mesh_viz.TestV4BundledModel.
# It is not yet on the Hub. ~146KB. Mirrors the other bundled viz assets above.
!feat/resources/au_to_mesh_pls_v4.npz

# marimo runtime cache (created next to notebooks during render)
**/__marimo__/

# Stray gifs animate_face writes to the render cwd (the real ones live in docs/images/)
/docs/*.gif

# Competitor model weights downloaded at runtime (LibreFace, etc.)
weights_libreface/
/tmp/
scripts/competitors/*manifest*.csv
/weights/

# Stray gifs animate_face writes when run from the repo root (the real ones
# live in docs/images/; mirrors the /docs/*.gif rule above)
/*.gif

# Local Claude Code session/agent state
/.claude/

# Code-review tooling scratch artifacts
/.review_*

# Stray detector output written by ad-hoc/example runs
/output.csv
